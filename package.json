{
  "name": "skml-indana-party-store-root",
  "version": "1.0.0",
  "description": "Root management for SKML Indana Party Store project",
  "main": "index.js",
  "scripts": {
    "client": "npm run dev --prefix client",
    "server": "npm run dev --prefix server",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "express": "^5.2.1",
    "razorpay": "^2.9.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
